# Production Environment Variables
# Copy this file to .env.local and fill in your production values

# Supabase Configuration (Production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# AI API Keys (Production)
GOOGLE_AI_API_KEY=your-production-gemini-api-key
GROQ_API_KEY=your-production-groq-api-key
OPENAI_API_KEY=your-production-openai-api-key

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# Security Configuration
NEXTAUTH_SECRET=your-nextauth-secret-key-minimum-32-characters
NEXTAUTH_URL=https://your-domain.com

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=20
RATE_LIMIT_WINDOW_MS=60000

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database Connection Pool (if using external pooler)
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30000

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
SENTRY_DSN=your-sentry-dsn-if-using

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS_PROTECTION=true