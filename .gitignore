# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================
# PRIVATE & SENSITIVE FILES - DO NOT COMMIT
# ============================================

# Environment files with real credentials
.env
.env*.local
.env.production
.env.development
.env.test

# Keep only the example file
!.env.example

# Backup and private folders
/private/
/backup/
*.backup

# API Keys and Secrets
*.key
*.pem
*.p12
*.pfx
secrets.json
credentials.json

# ============================================
# DEPENDENCIES
# ============================================
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
/vendor

# ============================================
# BUILD & CACHE
# ============================================

# Next.js
/.next/
/out/
.next/

# Production builds
/build
/dist

# TypeScript
*.tsbuildinfo
next-env.d.ts
*.tsbuildinfo.*

# SWC
/.swc/

# Testing
/coverage
/.nyc_output

# ============================================
# LOGS & DEBUG
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ============================================
# DEPLOYMENT
# ============================================
.vercel
.netlify
.firebase

# ============================================
# OS & IDE
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*.swn
.project
.classpath
.settings/

# ============================================
# TEMPORARY & MISC
# ============================================
*.tmp
*.temp
.cache
.temp/
tmp/

# Database files (if any local DB)
*.sqlite
*.sqlite3
*.db

# Compressed files
*.zip
*.tar.gz
*.rar
